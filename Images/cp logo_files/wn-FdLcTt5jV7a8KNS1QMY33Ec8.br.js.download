var MsaAuthV2SilentSSO;!function(MsaAuthV2SilentSSO){var customEvents=require("event.custom");MsaAuthV2SilentSSO.init=function(params){try{customEvents&&customEvents.bind&&customEvents.bind("onP1",function(){MsaV2SilentSSO(params)})}catch(ex){"function"==typeof sj_log2&&sj_log2("Error","Unable to initialize MSA Auth V2 silent SSO script","Identity","MsaAuthV2SilentSSO",null,null,{Message:ex.message,Stack:ex.stack})}};var MsaV2SilentSSO=function(params){if(params.ssoEndpoint){var ssoEndpoint=params.ssoEndpoint.replace("&amp;","&"),ssoFrameName="msaSsoFrame";try{if(document.getElementById(ssoFrameName))return;var frameElement_1=document.createElement("iframe");frameElement_1.id=ssoFrameName,frameElement_1.src=ssoEndpoint,frameElement_1.style.display="none",frameElement_1.title="MSA V2 SSO Frame",frameElement_1.setAttribute("data-priority","2"),document.body.appendChild(frameElement_1)}catch(err){console.log(err)}}}}(MsaAuthV2SilentSSO||(MsaAuthV2SilentSSO={}));